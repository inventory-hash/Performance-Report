<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Petpooja | Operations Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    body { background-color: #0d1117; color: #c9d1d9; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif; }
    .gh-card { background-color: #161b22; border: 1px solid #30363d; border-radius: 6px; }
    .gh-card:hover { border-color: #8b949e; }
    .status-badge { font-size: 12px; font-weight: 500; padding: 2px 10px; border-radius: 12px; border: 1px solid #30363d; }
    .progress-bar { height: 8px; border-radius: 4px; background-color: #30363d; overflow: hidden; }
    .progress-fill { height: 100%; background: linear-gradient(90deg, #238636, #2ea043); transition: width 1s ease-in-out; }
    .loader { border-top-color: #3b82f6; animation: spin 1s linear infinite; }
    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
  </style>
</head>
<body class="p-4 md:p-10">

  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4 border-b border-gray-700 pb-6">
      <div class="flex items-center">
        <div class="bg-gray-800 p-3 rounded-md mr-4 border border-gray-600">
          <i class="fa-solid fa-boxes-stacked text-2xl text-blue-400"></i>
        </div>
        <div>
          <h1 class="text-xl font-semibold text-white flex items-center">
            Petpooja-Inventory-Ops <span class="ml-2 text-xs font-normal text-gray-500 border border-gray-700 px-2 py-0.5 rounded-full">Public</span>
          </h1>
          <p class="text-sm text-gray-400 mt-1">Operational Activities & Task Tracking FY 2025-26</p>
        </div>
      </div>
      <div class="flex space-x-2">
        <button onclick="fetchData()" class="bg-[#21262d] hover:bg-[#30363d] text-gray-200 px-4 py-1.5 rounded-md border border-[#30363d] text-sm font-medium transition">
          <i class="fa-solid fa-rotate mr-2"></i>Sync Data
        </button>
        <button class="bg-[#238636] hover:bg-[#2ea043] text-white px-4 py-1.5 rounded-md text-sm font-medium transition">
          <i class="fa-solid fa-plus mr-2"></i>New Entry
        </button>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
      <div class="gh-card p-4">
        <div class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-2">Total Tasks</div>
        <div class="text-3xl font-bold text-white" id="total-tasks">11,896</div>
        <div class="text-xs text-blue-400 mt-2 font-medium"><i class="fa-solid fa-arrow-up"></i> 678% YoY Growth</div>
      </div>
      <div class="gh-card p-4">
        <div class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-2">Completed</div>
        <div class="text-3xl font-bold text-green-500" id="completed-tasks">11,369</div>
        <div class="mt-3 progress-bar"><div class="progress-fill" style="width: 95.6%"></div></div>
      </div>
      <div class="gh-card p-4">
        <div class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-2">Efficiency</div>
        <div class="text-3xl font-bold text-teal-400">95.6%</div>
        <div class="text-xs text-gray-500 mt-2 italic">Avg completion rate</div>
      </div>
      <div class="gh-card p-4">
        <div class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-2">Lead Gen</div>
        <div class="text-3xl font-bold text-purple-400">40+</div>
        <div class="text-xs text-gray-500 mt-2 italic">Daily Marketplace leads</div>
      </div>
    </div>

    <div class="gh-card overflow-hidden">
      <div class="bg-[#161b22] border-b border-[#30363d] p-4 flex items-center justify-between">
        <div class="flex items-center space-x-4">
          <span class="flex items-center text-sm font-semibold text-white">
            <i class="fa-solid fa-code-commit mr-2 text-gray-500"></i> Activity Feed
          </span>
          <span id="loading-indicator" class="loader rounded-full border-2 border-gray-600 h-4 w-4 hidden"></span>
        </div>
        <div class="text-xs text-gray-500">Showing last 12 months</div>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead class="bg-[#0d1117] text-gray-400 text-xs uppercase">
            <tr>
              <th class="p-4 border-b border-[#30363d]">Operation Category</th>
              <th class="p-4 border-b border-[#30363d]">Total</th>
              <th class="p-4 border-b border-[#30363d]">Status</th>
              <th class="p-4 border-b border-[#30363d] text-right">Latest Update</th>
            </tr>
          </thead>
          <tbody id="data-body" class="text-sm text-gray-300">
            <tr class="hover:bg-[#1c2128] border-b border-[#30363d]">
              <td class="p-4"><i class="fa-regular fa-file-lines mr-3 text-gray-500"></i><span class="text-blue-400 font-medium cursor-pointer hover:underline">Raw Material Management</span></td>
              <td class="p-4">9,376</td>
              <td class="p-4"><span class="status-badge bg-[#23863626] text-[#238636] border-[#23863666]">Completed</span></td>
              <td class="p-4 text-right text-gray-500">Mar 2026</td>
            </tr>
            <tr class="hover:bg-[#1c2128] border-b border-[#30363d]">
              <td class="p-4"><i class="fa-regular fa-file-lines mr-3 text-gray-500"></i><span class="text-blue-400 font-medium cursor-pointer hover:underline">Recipe & Material Linking</span></td>
              <td class="p-4">1,919</td>
              <td class="p-4"><span class="status-badge bg-[#23863626] text-[#238636] border-[#23863666]">Completed</span></td>
              <td class="p-4 text-right text-gray-500">Feb 2026</td>
            </tr>
            <tr class="hover:bg-[#1c2128]">
              <td class="p-4"><i class="fa-regular fa-file-lines mr-3 text-gray-500"></i><span class="text-blue-400 font-medium cursor-pointer hover:underline">Marketplace Leads</span></td>
              <td class="p-4">598</td>
              <td class="p-4"><span class="status-badge bg-[#a371f726] text-[#a371f7] border-[#a371f766]">Active</span></td>
              <td class="p-4 text-right text-gray-500">Ongoing</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="mt-6 flex flex-col md:flex-row justify-between text-xs text-gray-500 gap-2 px-2">
      <div class="flex items-center space-x-4">
        <span><i class="fa-solid fa-code mr-1"></i> Apps Script Engine</span>
        <span><i class="fa-solid fa-database mr-1"></i> Google Sheets DB</span>
      </div>
      <div>FY 2025–26 Internal Performance Metric Tracking</div>
    </div>
  </div>

  <script>
    function fetchData() {
      const loader = document.getElementById('loading-indicator');
      loader.classList.remove('hidden');
      
      // Communicates with Code.gs function
      google.script.run
        .withSuccessHandler(data => {
          loader.classList.add('hidden');
          console.log("Data synced successfully");
          // You can add logic here to re-render the table with dynamic data
        })
        .withFailureHandler(err => {
          loader.classList.add('hidden');
          alert("Sync failed: " + err);
        })
        .getDashboardData(); // Make sure this function exists in Code.gs
    }
  </script>
</body>
</html>
